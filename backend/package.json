{
  "name": "paramsync-backend",
  "version": "1.0.0",
  "description": "ParamSync Node.js/Express backend — replaces Oracle ORDS gateway",
  "main": "main.js",
  "type": "commonjs",
  "scripts": {
    "start": "node --max-old-space-size=4096 src/index.js",
    "dev": "nodemon --max-old-space-size=4096 src/index.js",
    "electron": "electron .",
    "build": "electron-builder --win",
    "test": "echo \"No tests yet\""
  },
  "dependencies": {
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "morgan": "^1.10.0",
    "oracledb": "^6.4.0",
    "uuid": "^9.0.0"
  },
  "devDependencies": {
    "electron": "^33.4.11",
    "electron-builder": "^25.1.8",
    "nodemon": "^3.0.2"
  },
  "build": {
    "appId": "com.hps.paramsync",
    "productName": "ParamSync",
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "src/**/*",
      "node_modules/**/*",
      "assets/**/*"
    ],
    "extraFiles": [
      {
        "from": "../frentend/dist/config-sync-app/browser",
        "to": "frentend/dist/config-sync-app/browser"
      }
    ],
    "win": {
      "target": "dir"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    }
  }
}
