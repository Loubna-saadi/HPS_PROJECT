# ─────────────────────────────────────────────
# ParamSync Backend — Environment Variables
# Copy this file to .env and fill in your values
# ─────────────────────────────────────────────

# Server
PORT=3000
NODE_ENV=development

# ─────────────────────────────────────────────
# Oracle DB connections (one per environment)
# These are the HPS Oracle DBs — read-only use
# (fetching PowerCard tables for comparison)
# ─────────────────────────────────────────────

# DEV environment
ORA_DEV_HOST=your-dev-host
ORA_DEV_PORT=1521
ORA_DEV_SERVICE=XEPDB1
ORA_DEV_USER=powercard_user
ORA_DEV_PASSWORD=your_password

# DEV_VAL environment
ORA_DEV_VAL_HOST=your-devval-host
ORA_DEV_VAL_PORT=1521
ORA_DEV_VAL_SERVICE=XEPDB1
ORA_DEV_VAL_USER=powercard_user
ORA_DEV_VAL_PASSWORD=your_password

# UAT environment
ORA_UAT_HOST=your-uat-host
ORA_UAT_PORT=1521
ORA_UAT_SERVICE=XEPDB1
ORA_UAT_USER=powercard_user
ORA_UAT_PASSWORD=your_password

# SIT environment
ORA_SIT_HOST=your-sit-host
ORA_SIT_PORT=1521
ORA_SIT_SERVICE=XEPDB1
ORA_SIT_USER=powercard_user
ORA_SIT_PASSWORD=your_password

# PROD environment
ORA_PROD_HOST=your-prod-host
ORA_PROD_PORT=1521
ORA_PROD_SERVICE=XEPDB1
ORA_PROD_USER=powercard_user
ORA_PROD_PASSWORD=your_password

# ─────────────────────────────────────────────
# Local file storage paths (relative to project)
# ─────────────────────────────────────────────
DATA_DIR=./data
